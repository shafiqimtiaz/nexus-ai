# Supabase (server-only — never expose service role key to the browser)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Anon key — used ONLY server-side by the auth client (sign in/out, session)
SUPABASE_ANON_KEY=
# Google Gemini (AI agent)
GOOGLE_GENERATIVE_AI_API_KEY=
# Google OAuth (Classroom) — added in later tasks
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
# App base URL (for OAuth redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000
